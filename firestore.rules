rules_version = '2';

// Modelo: só utilizadores com Firebase Auth (sessão válida). Nada de acesso anónimo.
// private/** fica sempre fechado ao cliente (segredos só via Admin SDK / Functions).
//
// Um único match para documentos de 1º nível (coleção/documento) evita esquecer uma
// coleção nova na lista — antes isso gerava "Missing or insufficient permissions"
// sem alterar a superfície de risco: qualquer utilizador autenticado já lia/escrevia
// nas mesmas coleções quando estavam enumeradas explicitamente.

service cloud.firestore {
  match /databases/{database}/documents {
    match /private/{document=**} {
      allow read, write: if false;
    }

    // Todas as coleções de raiz (usuarios, registros, config, agendamentos, …),
    // exceto "private", alinhadas ao uso atual da app (sem subcoleções).
    match /{collection}/{document} {
      allow read, write: if request.auth != null && collection != 'private';
    }
  }
}
