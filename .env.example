# Copie para .env e preencha (o ficheiro .env não deve ir para o Git).

# Firebase (obrigatório para a app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Opcional: token Meta só para desenvolvimento (produção: modal do CRM)
# VITE_META_ADS_ACCESS_TOKEN=

# Opcional: versão da Graph API (predefinido v22.0). Se tiveres 2500 em /leads, podes testar ex.: v23.0
# VITE_META_GRAPH_API_VERSION=v22.0

# Opcional: webhook N8N ao agendar reunião (barra rápida SDR)
# VITE_N8N_WEBHOOK_AGENDAMENTO=

# URL pública do site (Netlify) — usada para montar o endpoint do webhook
# VITE_SITE_URL=https://seu-crm.netlify.app

# Netlify → Environment variables (server-side, NÃO prefixo VITE_):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# CRM_WEBHOOK_SECRET=opcional_se_quiser_no_servidor

# Opcional: convidados extra no Google Agenda (contato@lvxdigital.com.br já é sempre incluído no código)
# VITE_GOOGLE_CALENDAR_DEFAULT_GUESTS=outro@empresa.com.br
