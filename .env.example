# Copie para .env e preencha (o ficheiro .env não deve ir para o Git).

# Firebase (obrigatório para a app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Opcional: região das Cloud Functions (default us-central1)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Opcional: token Meta só para desenvolvimento (produção: modal do CRM)
# VITE_META_ADS_ACCESS_TOKEN=

# Opcional: webhook N8N ao agendar reunião (barra rápida SDR)
# VITE_N8N_WEBHOOK_AGENDAMENTO=
